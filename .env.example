# 브리지/프런트 기본 주소
VITE_APP_URL=http://127.0.0.1:4173
VITE_PUBLIC_BRIDGE_URL=http://127.0.0.1:4174

# AI 라우팅 데이터 저장 경로
ARTEMIS_DATA_DIR=output/ai-router

# 서버 측 API 키 암호화용 비밀값
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# 기본 라우팅 모드
# auto-best-free | auto-best-free-coding | auto-best-free-fast | manual
DEFAULT_ROUTING_MODE=auto-best-free

# 타임아웃(ms)
FIRST_TOKEN_TIMEOUT_MS=20000
REQUEST_TIMEOUT_MS=120000

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_CANDIDATES=qwen/qwen3-30b-a3b:free,deepseek/deepseek-r1:free,google/gemma-3-27b-it:free
OPENROUTER_APP_TITLE=Artemis Orchestration
OPENROUTER_HTTP_REFERER=http://127.0.0.1:4173

# NVIDIA Build
NVIDIA_BUILD_API_KEY=
NVIDIA_BUILD_DEFAULT_CANDIDATES=meta/llama-3.1-70b-instruct,qwen/qwen2.5-coder-32b-instruct,microsoft/phi-4-mini-instruct

# Gemini Developer API
GEMINI_API_KEY=
GEMINI_DEFAULT_CANDIDATES=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite
